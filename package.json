{
  "name": "chord-transposer-web-extension",
  "version": "1.0.0",
  "description": "A chrome & firefox extension for transposing chords on webpages. Built with Vite and TypeScript.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnBra/vite-web-extension.git"
  },
  "scripts": {
    "build": "vite build --config vite.config.chrome.ts",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "dist:firefox": "yarn build:firefox && bash ./zip_firefox.sh",
    "dev": "nodemon --config nodemon.chrome.json",
    "dev:chrome": "nodemon --config nodemon.chrome.json",
    "dev:firefox": "nodemon --config nodemon.firefox.json",
    "autoformat": "eslint . --fix",
    "lint:chrome": "web-ext lint --source-dir dist_chrome",
    "lint:firefox": "web-ext lint --source-dir dist_firefox",
    "run:firefox-android": "yarn build:firefox && web-ext run --source-dir dist_firefox --target=firefox-android",
    "test": "node --test test/**/*.test.ts",
    "test:watch": "node --test --watch test/**/*.test.ts"
  },
  "type": "module",
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@types/chrome": "^0.1.11",
    "@types/node": "^24.9.1",
    "@types/webextension-polyfill": "^0.12.3",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "fs-extra": "^11.3.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "web-ext": "^10.1.0"
  }
}
